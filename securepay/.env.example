# FILE: .env.example
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. cp .env.example .env
#   2. Replace EVERY value below with a strong unique password
#   3. Never commit .env to git (it is in .gitignore)
#   4. Never share .env or store it in Slack/email/chat
#
# HOW TO GENERATE STRONG PASSWORDS:
#   Linux/Mac:  openssl rand -base64 32
#   Windows:    [System.Web.Security.Membership]::GeneratePassword(32,8)
# ─────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
DB_HOST=db


# Name of the MySQL database (no spaces, no special chars)
DB_NAME=securepay

# Application database user — low privilege (SELECT/INSERT/UPDATE/DELETE only)
# This is what the PHP app connects as. NOT root.
DB_USER=spuser

# Password for the application DB user.
# Use a minimum 20-character random string.
DB_PASS=REPLACE_WITH_STRONG_RANDOM_PASSWORD

# MySQL root password — used ONLY by Docker health check.
# The application never connects as root.
# Must be DIFFERENT from DB_PASS.
MYSQL_ROOT_PASSWORD=REPLACE_WITH_DIFFERENT_STRONG_PASSWORD


//Port Number for MySQL (default is 3306, only change if you know what you're doing)
DB_PORT=3306